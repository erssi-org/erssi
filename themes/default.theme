# When testing changes, the easiest way to reload the theme is with /RELOAD.
# This reloads the configuration file too, so if you did any changes remember
# to /SAVE it first. Remember also that /SAVE overwrites the theme file with
# old data so keep backups :)

# TEMPLATES:

# The real text formats that erssi uses are the ones you can find with
# /FORMAT command. Back in the old days all the colors and texts were mixed
# up in those formats, and it was really hard to change the colors since you
# might have had to change them in tens of different places. So, then came
# this templating system.

# Now the /FORMATs don't have any colors in them, and they also have very
# little other styling. Most of the stuff you need to change is in this
# theme file. If you can't change something here, you can always go back
# to change the /FORMATs directly, they're also saved in these .theme files.

# So .. the templates. They're those {blahblah} parts you see all over the
# /FORMATs and here. Their usage is simply {name parameter1 parameter2}.
# When erssi sees this kind of text, it goes to find "name" from abstracts
# block below and sets "parameter1" into $0 and "parameter2" into $1 (you
# can have more parameters of course). Templates can have subtemplates.
# Here's a small example:
#   /FORMAT format hello {colorify {underline world}}
#   abstracts = { colorify = "%G$0-%n"; underline = "%U$0-%U"; }
# When erssi expands the templates in "format", the final string would be:
#   hello %G%Uworld%U%n
# ie. underlined bright green "world" text.
# and why "$0-", why not "$0"? $0 would only mean the first parameter,
# $0- means all the parameters. With {underline hello world} you'd really
# want to underline both of the words, not just the hello (and world would
# actually be removed entirely).

# COLORS:

# You can find definitions for the color format codes in docs/formats.txt.

# There's one difference here though. %n format. Normally it means the
# default color of the terminal (white mostly), but here it means the
# "reset color back to the one it was in higher template". For example
# if there was /FORMAT test %g{foo}bar, and foo = "%Y$0%n", erssi would
# print yellow "foo" (as set with %Y) but "bar" would be green, which was
# set at the beginning before the {foo} template. If there wasn't the %g
# at start, the normal behaviour of %n would occur. If you _really_ want
# to use the terminal's default color, use %N.

# Nightfall theme - Tokyo Night inspired palette
# Synced with repartee (rustirc) default.theme
#
# Palette:
#   bg:       #1a1b26  fg:       #a9b1d6  fg_muted: #565f89
#   fg_dim:   #292e42  accent:   #7aa2f7  success:  #9ece6a
#   error:    #f7768e  warning:  #e0af68  info:     #7dcfff
#   purple:   #bb9af7  light_fg: #c0caf5  muted_ts: #6e738d


# default foreground color (%N) - -1 is the "default terminal color"
default_color = "-1";

# print timestamp/servertag at the end of line, not at beginning
info_eol = "false";

# these characters are automatically replaced with specified color
replaces = { "[]=" = "%Z565f89$*%n"; };

abstracts = {
  ##
  ## generic
  ##

  # text to insert at the beginning of each non-message line
  line_start = "%N";

  # timestamp styling - muted gray timestamp, accent blue middle dot
  timestamp = "%Z6e738d$*%Z7aa2f7·%N";

  # any kind of text that needs hilighting - plasma purple bold
  hilight = "%Zbb9af7%_$*%_%N";
  # any kind of error message - rose/crimson
  error = "%Zf7768e! $*%N";

  # channel name is printed - accent blue bold
  channel = "%Z7aa2f7%_$*%_%N";

  # nick is printed - bold
  nick = "%_$*%_";

  # nick host is printed - muted in brackets
  nickhost = "%Z565f89[$*]%N";

  # server name is printed - accent blue bold
  server = "%Z7aa2f7%_$*%_%N";

  # some kind of comment is printed - muted brackets
  comment = "%Z565f89[$*]%N";

  # reason for something is printed (part, quit, kick, ..)
  reason = "{comment $*}";

  # mode change is printed ([+o nick])
  mode = "{comment $*}";

  ##
  ## channel specific messages
  ##

  # highlighted nick/host is printed (joins)
  channick_hilight = "%Z9ece6a$*%n";
  chanhost_hilight = "{nickhost %Z565f89$*%n}";

  # nick/host is printed (parts, quits, etc.)
  channick = "%Za9b1d6$*%n";
  chanhost = "{nickhost $*}";

  # highlighted channel name is printed
  channelhilight = "%Z7aa2f7$*%n";

  # ban/ban exception/invite list mask is printed
  ban = "%Ze0af68$*%n";

  ##
  ## messages
  ##

  # the basic styling of how to print message, $0 = nick mode, $1 = nick
  # muted mode prefix, accent blue chevron separator
  msgnick = "%Z565f89$0$1%Z7aa2f7❯%N%| ";

  # message from you is printed. "msgownnick" specifies the styling of the
  # nick ($0 part in msgnick) and "ownmsgnick" specifies the styling of the
  # whole line.

  # $0 = nick mode, $1 = nick
  ownmsgnick = "{msgnick $0 $1-}";
  ownnick = "%Z9ece6a%_$*%_%N";

  # public message in channel, $0 = nick mode, $1 = nick
  pubmsgnick = "{msgnick $0 $1-}";
  pubnick = "%Z7aa2f7%_$*%_%N";

  # public message in channel meant for me, $0 = nick mode, $1 = nick
  # plasma purple for mentions
  pubmsgmenick = "{msgnick %Zbb9af7$0$1-}%Zbb9af7";
  menick = "%Zbb9af7%_$*%_%N";

  # public highlighted message in channel
  # $0 = highlight color, $1 = nick mode, $2 = nick
  # rose/crimson for highlighted messages
  pubmsghinick = "{msgnick %Zf7768e$1 %Zf7768e%_$0$2-%_%N}%Zf7768e";

  # channel name is printed with message
  msgchannel = "%Z565f89:%Z7aa2f7$*%n";

  # private message, $0 = nick, $1 = host
  privmsg = "%Z7dcfff[%Zf7768e$0%Z565f89(%Za9b1d6$1-%Z565f89)%Z7dcfff]%N ";

  # private message from you, $0 = "msg", $1 = target nick
  ownprivmsg = "%Z7dcfff[%Z9ece6a$0%Z565f89(%Z7aa2f7$1-%Z565f89)%Z7dcfff]%N ";

  # own private message in query
  ownprivmsgnick = "{msgnick  $*}";
  ownprivnick = "%Z9ece6a%_$*%_%N";

  # private message in query
  privmsgnick = "{msgnick  %Zf7768e$*%N}";

  ##
  ## Actions (/ME stuff)
  ##

  # used internally by this theme - warm amber
  action_core = "%Ze0af68* $*%N";

  # generic one that's used by most actions
  action = "{action_core $*} ";

  # own action, both private/public
  ownaction = "{action $*}";

  # own action with target, both private/public
  ownaction_target = "{action_core $0}%Z565f89:%Z7aa2f7$1%N ";

  # private action sent by others
  pvtaction = "%Ze0af68 (*) $*%N ";
  pvtaction_query = "{action $*}";

  # public action sent by others
  pubaction = "{action $*}";

  ##
  ## other IRC events
  ##

  # whois
  whois = "%# $[8]0 : $1-";

  # notices - cyan dashes, accent blue nick
  ownnotice = "%Z7dcfff[%Z9ece6a$0%Z565f89(%Z7aa2f7$1-%Z565f89)%Z7dcfff]%N ";
  notice = "%Z7dcfff-%Z7aa2f7$*%Z7dcfff-%N ";
  pubnotice = "%Z7dcfff-%Z7aa2f7$0$1-%Z7dcfff-%N %|";
  pubnotice_channel = "%Z565f89:%Zbb9af7$*";
  pvtnotice_host = "%Z565f89(%Zbb9af7$*%Z565f89)";
  servernotice = "%Z9ece6a!$*%N ";

  # CTCPs
  ownctcp = "%Z7dcfff[%Z9ece6a$0%Z565f89(%Z7aa2f7$1-%Z565f89)%Z7dcfff] ";
  ctcp = "%Z9ece6a$*%N";

  # wallops
  wallop = "%_$*%N: ";
  wallop_nick = "%N$*";
  wallop_action = "%Ze0af68 * $*%N ";

  # netsplits
  netsplit = "%Zf7768e$*%N";
  netjoin = "%Z9ece6a$*%N";

  # /names list
  names_prefix = "";
  names_nick = "[%_$0%_$1-] ";
  names_nick_op = "{names_nick $*}";
  names_nick_halfop = "{names_nick $*}";
  names_nick_voice = "{names_nick $*}";
  names_users = "[%Z9ece6a$*%N]";
  names_channel = "%Z7aa2f7$*%N";

  # DCC
  dcc = "%Z9ece6a$*%N";
  dccfile = "%_$*%_";

  # DCC chat, own msg/action
  dccownmsg = "%Z7dcfff[%Z9ece6a$0%Z565f89($1-%Z565f89)%Z7dcfff]%N ";
  dccownnick = "%Z9ece6a$*%N";
  dccownquerynick = "%_$*%N";
  dccownaction = "{action $*}";
  dccownaction_target = "{action_core $0}%Z565f89:%Z7aa2f7$1%N ";

  # DCC chat, others
  dccmsg = "%Z7dcfff[%Z7aa2f7$1-%Z565f89(%Z9ece6a$0%Z565f89)%Z7dcfff]%N ";
  dccquerynick = "%Z7aa2f7$*%N";
  dccaction = "%Ze0af68 (*dcc*) $*%N %|";

  ##
  ## statusbar
  ##

  # Statusbar background - dark
  sb_background = "%Z1a1b26";
  # Window border - accent blue pipe
  window_border = "%Z7aa2f7|%N";
  # Topic bar - accent blue + light fg
  sb_topic_bg = "%Z7aa2f7%Zc0caf5";
  sb = " %Z7aa2f7[%N$*%Z7aa2f7]%N";
  sbmode = "(%Z7aa2f7+%N$*)";
  sbservertag = ":$0 (change with ^X)";
  sbmore = " %Zf7768e<%Ze0af68<%Z565f89< %Nmore %Z565f89>%Ze0af68>%Zf7768e> ";
  sblag = "%Zf7768e!%N %Zf7768eLAG%N %Za9b1d6$0-%N seconds";
  sb_default_bg = "%Z1a1b26";
  sb_info1_bg = "%Z7aa2f7";
  sb_window_bg = "%Z7aa2f7%Zc0caf5";
  sb_window2_bg = "%Z7aa2f7%Zc0caf5";
  sb_info2_bg = "%Z7dcfff";

  # text at the beginning of statusbars. "sb" already puts a space there,
  # so we don't use anything by default.
  sbstart = "";
  # text at the end of statusbars. Use space so that it's never
  # used for anything.
  sbend = " ";

  topicsbstart = "{sbstart $*}";
  topicsbend = "{sbend $*}";

  prompt = "%Z7aa2f7[%N$*%Z7aa2f7]%N ";

  sbaway = " (%Z9ece6azZzZ%N)";
  sbnickmode = "$0";

  # activity in statusbar

  # muted separator
  sb_act_sep = "%Z565f89/%N";
  # muted activity text
  sb_act_text = "%Z565f89$*";
  # accent blue activity messages
  sb_act_msg = "%Z7aa2f7$*";
  # success green activity highlights
  sb_act_hilight = "%Z9ece6a$*";
  # accent blue highlight with color
  sb_act_hilight_color = "%Z7aa2f7$0$1-%N";

};
formats = {
  "fe-common/core" = {

    own_msg = "{ownmsgnick $2 {ownnick $0}}%Zc0caf5$1%N";
    own_msg_channel = "{ownmsgnick $3 {ownnick $0}{msgchannel $1}}%Zc0caf5$2%N";
    pubmsg_me = "{pubmsgmenick $2 {menick $0}}%Zbb9af7$1%N";
    pubmsg_me_channel = "{pubmsgmenick $3 {menick $0}{msgchannel $1}}%Zbb9af7$2%N";
    pubmsg_hilight = "{pubmsghinick $0 $3 $1}$2";
    pubmsg_hilight_channel = "{pubmsghinick $0 $4 $1{msgchannel $2}}$3";
    pubmsg = "{pubmsgnick $2 {pubnick $0}}%Za9b1d6$1%N";
    pubmsg_channel = "{pubmsgnick $3 {pubnick $0}{msgchannel $1}}%Za9b1d6$2%N";
    msg_private = "{privmsg $0 $1}$2";
    msg_private_query = "{privmsgnick $0}$2";

  };
  "fe-text" = {
    # === LEFT PANEL (Window List) ===
    # Format: $0 = window number, $1 = window name

    # Server header - accent blue bold
    sidepanel_header = "%Z7aa2f7%_$0.%N %Z7aa2f7%_$1%_%N";

    # Normal items - muted number, dim name
    sidepanel_item = "%Z565f89$0.%N %Z6e738d$1%N";

    # Selected items - warm amber number, light fg bold name
    sidepanel_item_selected = "%Ze0af68$0.%N %Zc0caf5%_$1%_%N";

    # === ACTIVITY HIERARCHY (by priority) ===

    # PRIORITY 4 (Highest): NICK MENTION - purple (plasma)
    sidepanel_item_nick_mention = "%Z565f89$0.%N %Zbb9af7$1%N";

    # PRIORITY 4 (Highest): QUERY MESSAGE - rose/crimson
    sidepanel_item_query_msg = "%Z565f89$0.%N %Zf7768e$1%N";

    # PRIORITY 3: CHANNEL ACTIVITY - success green
    sidepanel_item_activity = "%Z565f89$0.%N %Z9ece6a$1%N";

    # PRIORITY 1 (Lowest): EVENTS - dim (no change from normal)
    sidepanel_item_events = "%Z565f89$0.%N %Z6e738d$1%N";

    # PRIORITY 2: HIGHLIGHTS - warm amber
    sidepanel_item_highlight = "%Z565f89$0.%N %Ze0af68$1%N";

    # === RIGHT PANEL (Nicklist) ===

    # Owner - warm amber prefix, light fg nick
    sidepanel_nick_op_status = "%Ze0af68$0%N%Zc0caf5$1%N";

    # Voice users - cyan prefix, dim nick
    sidepanel_nick_voice_status = "%Z7dcfff$0%N%Z6e738d$1%N";

    # Normal users - muted
    sidepanel_nick_normal_status = " %Z565f89$1%N";
  };
};
